# Copy to .env for local experiments. Do not commit real secrets.

# Milvus Lite default:
MILVUS_URI=projects/08-industrial-rag/industrial_rag_demo.db
RAG_COLLECTION=rag_chunks_v1
RAG_OBJECT_STORE_DIR=projects/08-industrial-rag/object_store

# For Milvus Standalone from docker-compose.yml:
# MILVUS_URI=http://127.0.0.1:19530
# MILVUS_TOKEN=

# Teaching smoke backend, no model download:
RAG_EMBEDDING_BACKEND=hash
RAG_RERANK_BACKEND=lexical
RAG_IMAGE_EMBEDDING_BACKEND=hash
EMBEDDING_DIM=1024
IMAGE_EMBEDDING_DIM=1024
RAG_PII_POLICY=warn
RAG_MAX_CONTEXT_CHARS=6000
RAG_MAX_CHUNKS_PER_DOC=2
# Empty means no threshold; set a float to reject low-confidence rerank results.
RAG_MIN_RERANK_SCORE=
RAG_QUERY_REWRITE_BACKEND=none

# API auth context. Teaching default can keep this off; production should turn it on.
RAG_REQUIRE_AUTH_CONTEXT=0
# If set, /search and /query require Authorization: Bearer <token>.
RAG_API_TOKEN=

# Production-like local models:
# HF_ENDPOINT=https://hf-mirror.com
# RAG_EMBEDDING_BACKEND=bge
# RAG_RERANK_BACKEND=bge
# EMBEDDING_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RAG_IMAGE_EMBEDDING_BACKEND=clip
# IMAGE_EMBEDDING_MODEL=openai/clip-vit-base-patch32
# IMAGE_EMBEDDING_DIM=512

# OpenAI-compatible LLM gateway:
OPENAI_BASE_URL=http://<newapi-host>:<port>/v1
OPENAI_API_KEY=
LLM_MODEL=gemini-3-flash-preview
