# Choose one Milvus mode for your shell or process:
# - Local Milvus Lite file (for development, leave empty for Docker deployment):
RAG_MILVUS_URI=
# - Remote/standalone Milvus endpoint (set by docker-compose for Docker deployment):
MILVUS_URI=
MILVUS_TOKEN=
RAG_MILVUS_GRPC_KEEPALIVE_TIME_MS=60000
RAG_MILVUS_GRPC_KEEPALIVE_TIMEOUT_MS=20000
RAG_MILVUS_GRPC_KEEPALIVE_PERMIT_WITHOUT_CALLS=0

RAG_COLLECTION=rag_chunks_v1
RAG_OBJECT_STORE_DIR=projects/09-production-rag/object_store
RAG_OBJECT_STORE_BACKEND=local
RAG_S3_ENDPOINT_URL=http://127.0.0.1:9000
RAG_S3_ACCESS_KEY_ID=minioadmin
RAG_S3_SECRET_ACCESS_KEY=minioadmin
RAG_S3_BUCKET=production-rag
RAG_S3_PREFIX=app
RAG_RUNTIME_DIR=projects/09-production-rag/runtime
RAG_TEXT_INPUT=
RAG_IMAGE_INPUT=

RAG_REQUIRE_AUTH_CONTEXT=0
RAG_API_TOKEN=
RAG_FIXED_TEST_LOGIN_TOKEN=production-rag-fixed-test-login-token
RAG_AUTH_TOKEN_CACHE_TTL_SECONDS=2

# Docker Compose defaults to hosted API models and does not load local torch/transformers weights.
RAG_EMBEDDING_BACKEND=siliconflow
RAG_RERANK_BACKEND=siliconflow
RAG_IMAGE_EMBEDDING_BACKEND=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
SILICONFLOW_URL=https://api.siliconflow.cn
SILICONFLOW_API_KEY=
IMAGE_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
RAG_QUERY_IMAGE_CAPTION_BACKEND=siliconflow
RAG_QUERY_IMAGE_CAPTION_MODEL=Qwen/Qwen3-VL-8B-Instruct
EMBEDDING_DIM=1024
IMAGE_EMBEDDING_DIM=1024
RAG_MODEL_DEVICE=auto
RAG_MODEL_DTYPE=auto
RAG_EMBED_BATCH_SIZE=8
RAG_EMBED_MAX_LENGTH=8192
RAG_RERANK_BATCH_SIZE=8
RAG_RERANK_MAX_LENGTH=1024
RAG_IMAGE_EMBED_BATCH_SIZE=8

RAG_QUERY_REWRITE_BACKEND=llm
RAG_QUERY_REWRITE_HISTORY_TURNS=6
RAG_QUERY_REWRITE_MAX_TOKENS=256
RAG_ARTIFACT_LLM_WORKERS=3
RAG_MINDMAP_CHUNK_CHARS=230000
RAG_TABLE_CHUNK_CHARS=230000
RAG_SOURCE_GUIDE_LLM_WORKERS=3
RAG_SOURCE_GUIDE_CHUNK_CHARS=230000
RAG_INGEST_WORKERS=2
RAG_INGEST_QUEUE_LIMIT=32
RAG_INGEST_TENANT_QUEUE_LIMIT=8
RAG_MODEL_API_RETRIES=3
RAG_MODEL_API_BACKOFF_SECONDS=0.5
RAG_MODEL_API_BACKOFF_MAX_SECONDS=8
RAG_EVENT_MAX_JSON_BYTES=65536
RAG_EVENT_MAX_STRING_CHARS=4096
RAG_EVENT_MAX_LIST_ITEMS=100
RAG_EVENT_MAX_DICT_ITEMS=200
RAG_MILVUS_UPSERT_BATCH_SIZE=512
RAG_ANSWER_BACKEND=llm
RAG_MAX_CONTEXT_CHARS=6000
RAG_MAX_CHUNKS_PER_DOC=2
RAG_MIN_RERANK_SCORE=
RAG_MAX_QUERY_IMAGE_BYTES=2097152
RAG_MAX_QUERY_REQUEST_BYTES=4456448
RAG_MAX_CONVERSATION_REQUEST_BYTES=8912896
RAG_MAX_CONVERSATION_IMAGES=4
RAG_MAX_CONVERSATION_IMAGE_BYTES=4194304

# Required for query rewrite, answer generation, and Studio mind map generation.
# These variables are injected via env_file (./.env) into the container at runtime.
# docker-compose resolves 'environment' section variables at parse time from the
# shell or a .env file in the compose directory; do NOT rely on it for variable
# renaming across different env files.
NEW_API_URL=https://api.siliconflow.cn
NEW_API_KEY=
RAG_LLM_BASE_URL=
RAG_LLM_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

HF_ENDPOINT=
HF_HUB_DISABLE_XET=
HF_ENABLE_PARALLEL_LOADING=
HF_PARALLEL_LOADING_WORKERS=

# Docker Compose MinIO defaults
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Docker Compose PostgreSQL metadata defaults
POSTGRES_DB=production_rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password
RAG_METADATA_DATABASE_URL=postgresql://rag:rag_password@127.0.0.1:5432/production_rag
